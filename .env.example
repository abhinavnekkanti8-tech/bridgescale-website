# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# ── Database ──
DATABASE_URL="postgresql://platform:platform@localhost:5432/platform"
DB_USER=platform
DB_PASSWORD=platform
DB_NAME=platform

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Session / Auth ──
SESSION_SECRET=change_this_to_a_long_random_secret_in_production
SESSION_MAX_AGE_MS=86400000

# ── AI Provider (OpenAI) ──
OPENAI_API_KEY=sk-dummy-replace-with-real-key
OPENAI_MODEL=gpt-4o

# ── Payment Gateway (Stripe) ──
STRIPE_SECRET_KEY=sk_test_dummy_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_dummy_replace_with_real_key
STRIPE_PUBLISHABLE_KEY=pk_test_dummy_replace_with_real_key

# ── E-Signature Provider ──
ESIGN_PROVIDER=docusign
ESIGN_API_KEY=dummy_replace_with_real_key
ESIGN_ACCOUNT_ID=dummy_account_id

# ── Object Storage (S3-compatible) ──
S3_BUCKET=platform-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=dummy_access_key
S3_SECRET_KEY=dummy_secret_key
S3_ENDPOINT=

# ── Email Provider ──
EMAIL_PROVIDER=resend
EMAIL_API_KEY=dummy_replace_with_real_key
EMAIL_FROM=noreply@platform.com

# ── Application ──
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
